<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FBFF"
    android:fillViewport="true"
    tools:context=".ui.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="5dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/homeSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            app:strokeColor="#DCEFFD"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/todayLabelTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Hydration"
                    android:textColor="#6F7A85"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/speechBubbleCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="#EEF7FF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#DCEFFD"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/speechBubbleTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:text="Let's drink some water!"
                        android:textColor="#22303C"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <FrameLayout
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/waterProgressBar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        app:indicatorColor="@color/aqua_blue"
                        app:indicatorSize="240dp"
                        app:indicatorInset="0dp"
                        app:trackColor="#DDEFFC"
                        app:trackThickness="14dp" />

                    <ImageView
                        android:id="@+id/leftDropImageView"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_water_drop"
                        app:tint="@color/aqua_blue" />

                    <ImageView
                        android:id="@+id/rightDropImageView"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_water_drop"
                        app:tint="@color/aqua_blue" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <ImageView
                            android:id="@+id/centerMascotImageView"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:alpha="0.90"
                            android:src="@drawable/ic_water_drop"
                            app:tint="#7BC8F6" />

                        <TextView
                            android:id="@+id/progressPercentTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center"
                            android:text="0%"
                            android:textColor="#16202A"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/progressSubTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="completed"
                            android:textColor="#7A8794"
                            android:textSize="13sp" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/waterIntakeTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0.00 L / 0.00 L"
                    android:textColor="#16202A"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/goalHintTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Stay on track with your daily goal"
                    android:textColor="#7A8794"
                    android:textSize="14sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/quickAddLabelTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Quick Add"
            android:textColor="#22303C"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn250"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="250 ml"
                android:textAllCaps="false"
                android:textColor="@color/aqua_blue"
                app:cornerRadius="20dp"
                app:strokeColor="@color/aqua_blue"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn500"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="500 ml"
                android:textAllCaps="false"
                android:textColor="@color/aqua_blue"
                app:cornerRadius="20dp"
                app:strokeColor="@color/aqua_blue"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn750"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="750 ml"
                android:textAllCaps="false"
                android:textColor="@color/aqua_blue"
                app:cornerRadius="20dp"
                app:strokeColor="@color/aqua_blue"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/customAddLabelTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Custom Add"
            android:textColor="#22303C"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="22dp"
            app:cardElevation="3dp"
            app:strokeColor="#E6EEF5"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <EditText
                    android:id="@+id/mlToAddEditText"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:autofillHints=""
                    android:backgroundTint="#C9D4DE"
                    android:hint="Enter ml to add"
                    android:importantForAutofill="no"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addButton"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginStart="12dp"
                    android:minWidth="132dp"
                    android:backgroundTint="@color/aqua_blue"
                    android:text="Add Water"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_water_drop"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="@android:color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteTodayButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="22dp"
            android:text="Delete Today's Logs"
            android:textAllCaps="false"
            android:textColor="#D32F2F"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#D32F2F"
            app:strokeColor="#F1B9B9"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/todayLogsTitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Today's Sips"
            android:textColor="#22303C"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/todayLogsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="22dp"
            app:cardElevation="3dp"
            app:strokeColor="#E6EEF5"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/emptyLogsTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"
                    android:text="No water logs added today yet."
                    android:textColor="#8A8A8A"
                    android:textSize="14sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/todayLogsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    tools:listitem="@layout/item_today_sip" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>